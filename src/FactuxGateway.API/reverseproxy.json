{
  "ReverseProxy": {
    "Routes": {
      "auth-token-route": {
        "ClusterId": "factuxBusinessApi",
        "Match": {
          "Path": "/api/Auth/token",
          "Methods": [ "POST" ]
        }
      },
      "issuers-list-route": {
        "ClusterId": "factuxBusinessApi",
        "Match": {
          "Path": "/api/Issuers",
          "Methods": [ "GET" ]
        }
      },
      "issuers-create-route": {
        "ClusterId": "factuxBusinessApi",
        "Match": {
          "Path": "/api/Issuers",
          "Methods": [ "POST" ]
        }
      },
      "issuers-update-route": {
        "ClusterId": "factuxBusinessApi",
        "Match": {
          "Path": "/api/Issuers",
          "Methods": [ "PUT" ]
        }
      },
      "issuers-by-id-route": {
        "ClusterId": "factuxBusinessApi",
        "Match": {
          "Path": "/api/Issuers/{issuerId}",
          "Methods": [ "GET", "DELETE" ]
        }
      }
    }
  }
}
